<%- include('partials/header') %>
<main class="container" style="margin-top: 20px;">
    <h2><%= pageTitle %></h2>
    
    <div style="background-color: #fff; border: 1px solid #ddd; border-radius: 6px; overflow-x: auto; margin-top: 20px;">
        <table style="width: 100%; border-collapse: collapse; text-align: left;">
            <thead>
                <tr style="background-color: #343a40; color: white;">
                    <th style="padding: 12px;">Name</th>
                    <th style="padding: 12px;">Email (Username)</th>
                    <th style="padding: 12px;">Role</th>
                </tr>
            </thead>
            <tbody>
                <% if (users && users.length > 0) { %>
                    <% users.forEach(u => { %>
                        <tr style="border-bottom: 1px solid #eee;">
                            <td style="padding: 12px; font-weight: bold;"><%= u.user_name %></td>
                            <td style="padding: 12px; color: #555;"><%= u.user_email %></td>
                            <td style="padding: 12px;">
                                <span style="background-color: <%= u.user_role === 'admin' ? '#007bff' : '#6c757d' %>; color: white; padding: 4px 10px; border-radius: 12px; font-size: 0.85em; font-weight: bold; text-transform: uppercase;">
                                    <%= u.user_role %>
                                </span>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr><td colspan="3" style="padding: 15px; text-align: center; color: #666;">No users found.</td></tr>
                <% } %>
            </tbody>
        </table>
    </div>

    <div style="margin-top: 20px;">
        <a href="/dashboard" style="color: #007bff; text-decoration: none; font-weight: bold;">← Back to Dashboard</a>
    </div>
</main>
<%- include('partials/footer') %>