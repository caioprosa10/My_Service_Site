<%- include('partials/header') %>
<main class="container">
    <h2><%= pageTitle %></h2>
    <% if (error_msg && error_msg.length > 0) { %><p style="color: red; font-weight: bold;"><%= error_msg %></p><% } %>
    
    <form action="/project/<%= project.project_id %>/assign-categories" method="POST" style="margin-top: 20px;">
        <div style="margin-bottom: 20px;">
            <% allCategories.forEach(function(cat) { %>
                <div style="margin-bottom: 8px;">
                    <input 
                        type="checkbox" 
                        id="cat_<%= cat.category_id %>" 
                        name="categories" 
                        value="<%= cat.category_id %>"
                        <%= currentCategoryIds.includes(cat.category_id) ? 'checked' : '' %>
                    >
                    <label for="cat_<%= cat.category_id %>" style="margin-left: 5px;"><%= cat.category_name %></label>
                </div>
            <% }) %>
        </div>
        <button type="submit" style="padding: 10px 15px; background-color: #007bff; color: white; border: none; cursor: pointer;">Save Assignments</button>
        <a href="/project/<%= project.project_id %>" style="margin-left: 10px; color: #555; text-decoration: none;">Cancel</a>
    </form>
</main>
<%- include('partials/footer') %>