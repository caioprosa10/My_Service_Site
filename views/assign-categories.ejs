<%- include('partials/header') %>
<main class="container">
    <h2><%= pageTitle %></h2>
    <p style="margin-bottom: 20px; color: #666;">Check the categories you want to assign to <strong><%= project.project_name %></strong>.</p>

    <form action="/project/<%= project.project_id %>/assign-categories" method="POST" style="max-width: 500px; background-color: #fff; padding: 20px; border: 1px solid #ddd; border-radius: 6px;">
        <div style="margin-bottom: 20px;">
            <% categories.forEach(category => { %>
                <div style="margin-bottom: 12px; display: flex; align-items: center;">
                    <input type="checkbox" id="cat_<%= category.category_id %>" name="categories" value="<%= category.category_id %>" 
                        <%= currentIds.includes(category.category_id.toString()) ? 'checked' : '' %> 
                        style="width: 18px; height: 18px; margin-right: 10px; cursor: pointer;">
                    <label for="cat_<%= category.category_id %>" style="font-size: 1.05em; cursor: pointer; user-select: none;"><%= category.category_name %></label>
                </div>
            <% }) %>
        </div>

        <button type="submit" style="padding: 10px 20px; background-color: #28a745; color: white; border: none; border-radius: 4px; cursor: pointer; font-weight: bold;">Save Assignments</button>
        <a href="/project/<%= project.project_id %>" style="margin-left: 15px; color: #555; text-decoration: none;">Cancel</a>
    </form>
</main>
<%- include('partials/footer') %>