<%- include('partials/header') %>
<main class="container">
    <h2><%= pageTitle %></h2>
    <p>Welcome to your dashboard, <%= (typeof locals !== 'undefined' && locals.user) ? locals.user.user_name : ((typeof user !== 'undefined' && user) ? user.user_name : '') %>!</p>

    <% if (typeof success_msg !== 'undefined' && success_msg.length > 0) { %><p style="color: green; font-weight: bold;"><%= success_msg %></p><% } %>

    <div style="margin-top: 40px;">
        <h3 style="border-bottom: 2px solid #007bff; padding-bottom: 10px; display: inline-block;">My Volunteered Projects</h3>
        
        <% if (typeof volunteeredProjects !== 'undefined' && volunteeredProjects && volunteeredProjects.length > 0) { %>
            <ul style="list-style: none; padding: 0; margin-top: 20px;">
                <% volunteeredProjects.forEach(function(project) { %>
                    <li style="border: 1px solid #ddd; padding: 15px; margin-bottom: 15px; border-radius: 6px; display: flex; justify-content: space-between; align-items: center; background-color: #fff;">
                        <div>
                            <h4 style="margin: 0;"><a href="/project/<%= project.project_id %>" style="text-decoration: none; color: #333;"><%= project.project_name %></a></h4>
                            <p style="margin: 5px 0 0; color: #666; font-size: 0.9em;">
                                📍 <%= project.location %> | 📅 
                                <% 
                                    let d = new Date(project.project_date);
                                    let dateStr = d.toLocaleDateString();
                                %>
                                <%= dateStr %>
                            </p>
                        </div>
                        <form action="/project/<%= project.project_id %>/unvolunteer" method="POST" style="margin: 0;">
                            <button type="submit" style="padding: 8px 12px; background-color: #dc3545; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 0.9em;">Remove</button>
                        </form>
                    </li>
                <% }) %>
            </ul>
        <% } else { %>
            <div style="margin-top: 20px; padding: 20px; background-color: #f9f9f9; border-radius: 6px; text-align: center;">
                <p style="color: #666; font-size: 1.1em;">You haven't volunteered for any projects yet.</p>
                <a href="/projects" style="display: inline-block; margin-top: 10px; padding: 10px 15px; background-color: #28a745; color: white; text-decoration: none; border-radius: 4px; font-weight: bold;">Find Projects to Help</a>
            </div>
        <% } %>
    </div>
</main>
<%- include('partials/footer') %>