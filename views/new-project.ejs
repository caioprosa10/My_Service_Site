<%- include('partials/header') %>
<main class="container">
    <h2><%= pageTitle %></h2>
    <% if (error_msg && error_msg.length > 0) { %><p style="color: red; font-weight: bold;"><%= error_msg %></p><% } %>
    
    <form action="/new-project" method="POST" style="max-width: 500px; margin-top: 20px;">
        <div style="margin-bottom: 15px;">
            <label for="project_name" style="display: block; font-weight: bold;">Project Name:</label>
            <input type="text" id="project_name" name="project_name" required minlength="3" style="width: 100%; padding: 8px;">
        </div>
        
        <div style="margin-bottom: 15px;">
            <label for="project_description" style="display: block; font-weight: bold;">Description:</label>
            <textarea id="project_description" name="project_description" required rows="4" style="width: 100%; padding: 8px;"></textarea>
        </div>

        <div style="margin-bottom: 15px;">
            <label for="location" style="display: block; font-weight: bold;">Location:</label>
            <input type="text" id="location" name="location" required style="width: 100%; padding: 8px;">
        </div>

        <div style="margin-bottom: 15px;">
            <label for="project_date" style="display: block; font-weight: bold;">Date:</label>
            <input type="date" id="project_date" name="project_date" required style="width: 100%; padding: 8px;">
        </div>

        <div style="margin-bottom: 15px;">
            <label for="organization_id" style="display: block; font-weight: bold;">Organization:</label>
            <select id="organization_id" name="organization_id" required style="width: 100%; padding: 8px;">
                <% organizations.forEach(function(org) { %>
                    <option value="<%= org.organization_id %>"><%= org.organization_name %></option>
                <% }) %>
            </select>
        </div>
        <button type="submit" style="padding: 10px 15px; background-color: #28a745; color: white; border: none; cursor: pointer;">Create Project</button>
        <a href="/projects" style="margin-left: 10px; color: #555; text-decoration: none;">Cancel</a>
    </form>
</main>
<%- include('partials/footer') %>