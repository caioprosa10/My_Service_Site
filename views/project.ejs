<%- include('partials/header') %>
<main class="container">
    <h2><%= project.project_name %></h2>
    <p><%= project.description %></p>
    
    <div style="margin: 20px 0;">
        <a href="/project/<%= project.project_id %>/assign-categories" style="background-color: #007bff; color: white; padding: 10px 15px; text-decoration: none; border-radius: 5px;">Update Categories</a>
    </div>

    <div class="tags" style="margin-top: 20px;">
        <strong>Category Tags:</strong>
        <% if (categories.length > 0) { %>
            <% categories.forEach(function(cat) { %>
                <a href="/category/<%= cat.category_id %>" style="background: #eee; padding: 5px 10px; text-decoration: none; border-radius: 5px; margin-right: 5px;">
                    <%= cat.category_name %>
                </a>
            <% }) %>
        <% } else { %>
            <span>No tags assigned.</span>
        <% } %>
    </div>
</main>
<%- include('partials/footer') %>