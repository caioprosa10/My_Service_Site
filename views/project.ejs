<%- include('partials/header') %>
<main class="container">
    <h2><%= pageTitle %></h2>

    <% if (success_msg && success_msg.length > 0) { %><p style="color: green; font-weight: bold;"><%= success_msg %></p><% } %>
    <% if (error_msg && error_msg.length > 0) { %><p style="color: red; font-weight: bold;"><%= error_msg %></p><% } %>

    <div style="margin-bottom: 20px;">
        <p><strong>Description:</strong> <%= project.description || project.project_description %></p>
        <p><strong>Location:</strong> <%= project.location %></p>
        <p><strong>Date:</strong> 
            <% if(project.project_date) { %>
                <%= new Date(project.project_date).toLocaleDateString() %>
            <% } %>
        </p>
    </div>

    <div style="margin-top: 30px; padding: 20px; background-color: #f8f9fa; border-radius: 8px; text-align: center; border: 1px solid #ddd;">
        <% if (locals.user) { %>
            <% if (typeof isVolunteered !== 'undefined' && isVolunteered) { %>
                <h4 style="color: #28a745; margin-bottom: 10px;">✓ You are volunteering for this project.</h4>
                <form action="/project/<%= project.project_id %>/unvolunteer" method="POST">
                    <button type="submit" style="padding: 10px 15px; background-color: #dc3545; color: white; border: none; border-radius: 4px; cursor: pointer; font-weight: bold;">Remove me as a Volunteer</button>
                </form>
            <% } else { %>
                <h4 style="margin-bottom: 10px;">Interested in helping out?</h4>
                <form action="/project/<%= project.project_id %>/volunteer" method="POST">
                    <button type="submit" style="padding: 10px 15px; background-color: #007bff; color: white; border: none; border-radius: 4px; cursor: pointer; font-weight: bold;">Volunteer for this Project</button>
                </form>
            <% } %>
        <% } else { %>
            <p style="color: #666; font-style: italic; margin: 0;">Please <a href="/login" style="color: #007bff; text-decoration: none;">log in</a> to volunteer for this project.</p>
        <% } %>
    </div>
</main>
<%- include('partials/footer') %>