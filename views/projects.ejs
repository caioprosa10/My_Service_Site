<%- include('partials/header') %>
<main class="container" style="margin-top: 20px;">
    <h2><%= pageTitle %></h2>

    <% if (locals.user && locals.user.user_role.toLowerCase() === 'admin') { %>
        <div style="margin-bottom: 20px;">
            <a href="/new-project" style="display: inline-block; background-color: #007bff; color: white; padding: 10px 15px; border-radius: 4px; text-decoration: none; font-weight: bold;">Add New Project</a>
        </div>
    <% } %>

    <div style="background-color: #fff; border: 1px solid #ddd; border-radius: 6px; padding: 20px;">
        <% if (projects && projects.length > 0) { %>
            <ul style="padding-left: 10px; list-style-type: none;">
                <% projects.forEach(project => { %>
                    <li style="padding: 12px 0; border-bottom: 1px solid #eee; display: flex; justify-content: space-between; align-items: center;">
                        <div>
                            <a href="/project/<%= project.project_id %>" style="font-weight: bold; color: #0056b3; text-decoration: none; font-size: 1.1em;"><%= project.project_name %></a>
                            <p style="margin: 5px 0 0 0; color: #666;"><%= project.description %></p>
                        </div>
                        
                        <% if (locals.user && locals.user.user_role.toLowerCase() === 'admin') { %>
                            <a href="/edit-project/<%= project.project_id %>" style="color: #dc3545; text-decoration: none; font-size: 0.9em;">[Edit]</a>
                        <% } %>
                    </li>
                <% }) %>
            </ul>
        <% } else { %>
            <p style="color: #666; font-style: italic;">No projects found.</p>
        <% } %>
    </div>
</main>
<%- include('partials/footer') %>